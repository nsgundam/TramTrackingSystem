# PostgreSQL
POSTGRES_USER=shuttle_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=shuttle_tracking_backend

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=8h
SENDER_JWT_EXPIRES_IN=15m

# TTN webhook authentication
TTN_WEBHOOK_SECRET=your_ttn_webhook_secret_here

# Development-only seed/simulator fixture contract. These IDs must match prisma/seed.js.
SEED_ADMIN_PASSWORD=
TRACKING_SOURCE_ID_MOBILE=TS_MOB_01
TRACKING_VEHICLE_ID_MOBILE=VH001
TRACKING_SOURCE_ID_MOBILE_2=TS_MOB_02
TRACKING_VEHICLE_ID_MOBILE_2=VH002
TRACKING_SOURCE_ID_ESP32=TS_ESP_01
TRACKING_VEHICLE_ID_ESP32=VH001
TTN_DEVICE_ID=sensor-c4
TTN_VEHICLE_ID=VH003

# Set these only in an ignored local .env before seeding/smoke testing.
TRACKING_SOURCE_SECRET_MOBILE=
TRACKING_SOURCE_SECRET_ESP32=
